<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- Constructor-injected Spring beans store their collaborators by design — that's dependency
         injection, not exposed mutable state. SpotBugs raises EI_EXPOSE_REP2 whenever a bean stores
         a constructor-injected concrete service (HueBridgeService, MqttConnection, DeviceService);
         the classes below are the ones that inject such a service. The check stays active everywhere
         else (e.g., the response/request DTOs still need defensive copies). -->
    <Match>
        <Bug pattern="EI_EXPOSE_REP2"/>
        <Or>
            <Class name="org.felixgeisler.smarthome.device.DeviceController"/>
            <Class name="org.felixgeisler.smarthome.integration.hue.HueController"/>
            <Class name="org.felixgeisler.smarthome.integration.hue.HueDeviceAdapter"/>
            <Class name="org.felixgeisler.smarthome.integration.mqtt.MqttController"/>
            <Class name="org.felixgeisler.smarthome.integration.mqtt.MqttSensorListener"/>
        </Or>
    </Match>
</FindBugsFilter>
