# Copy to sensor-node.env and adjust. Do NOT commit the real file — it may hold the broker
# password. The systemd unit loads it via EnvironmentFile.

# Broker the node publishes to. One Pi (the "broker Pi") runs the broker; point every node at it:
#   - on the broker Pi itself: localhost
#   - on any other node:       the broker Pi's LAN IP (e.g. 192.168.1.21)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# Uncomment if you enabled password auth on the broker (see README hardening section).
# MQTT_USERNAME=smarthome
# MQTT_PASSWORD=change-me

# This node's id. MUST match the device's externalId registered on the hub, because the hub
# routes readings by topic: home/<NODE_ID>/<sensor-key>.
NODE_ID=living-room
TOPIC_PREFIX=home

# How often to publish a reading, in seconds. Lower = livelier dashboard; raise to save power
# and traffic (environmental values change slowly anyway).
INTERVAL_SECONDS=5

# BME690 I2C address is auto-detected (0x77 or 0x76); uncomment only to force a specific one.
# I2C_ADDRESS=0x77

# Read CO2 from an SCD4x (SCD40/SCD41) on the shared I2C bus (fixed address 0x62). Set to
# false for a node without a CO2 sensor — then the SCD4x library is not needed.
ENABLE_CO2=true
