/hub/mvnw text eol=lf
*.cmd text eol=crlf
# Shell-sourced config must stay LF (CRLF/BOM break `source` in bash).
cognitive-core.conf text eol=lf
.claude/hooks/*.sh text eol=lf
# Pi files run on Linux: a CRLF shebang breaks the script, CRLF breaks the systemd unit.
infrastructure/sensor-node/*.sh text eol=lf
infrastructure/sensor-node/*.service text eol=lf
